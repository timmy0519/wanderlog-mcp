# Wanderdog configuration
#
# Copy this file to `.env` and fill in your values, then Wanderdog will
# pick them up on startup. `.env` is gitignored — never commit it.

# REQUIRED — your Wanderlog session cookie.
#
# How to get it:
#   1. Log in to https://wanderlog.com in your browser
#   2. Open DevTools (F12 or right-click → Inspect)
#   3. Chrome: Application tab → Storage → Cookies → https://wanderlog.com
#      Firefox: Storage tab → Cookies → https://wanderlog.com
#   4. Find the row named `connect.sid`
#   5. Double-click the `Value` column, copy the entire string
#
# Paste the value below. It will look like `s%3A...` (URL-encoded).
# Valid for ~1 year from issue. Treat as a password — it grants full
# access to your Wanderlog account.
WANDERLOG_COOKIE=s%3APASTE_YOUR_CONNECT_SID_VALUE_HERE

# OPTIONAL — a trip key from your account to use in integration tests.
# Find it in the URL when viewing a trip: wanderlog.com/plan/{KEY}
# Only needed if you run `npm run test:integration`.
WANDERLOG_TRIP_KEY=

# OPTIONAL — override the Wanderlog base URL.
# Useful for staging environments. Leave blank to use production.
# WANDERLOG_BASE_URL=https://wanderlog.com

# OPTIONAL — override the WebSocket base URL.
# WANDERLOG_WS_BASE_URL=wss://wanderlog.com

# OPTIONAL — custom User-Agent string sent with requests.
# WANDERLOG_USER_AGENT=

# OPTIONAL — default currency label for hotel-search prices.
# ISO 4217 code (e.g. INR, USD, EUR, ARS). Used only to LABEL the response
# when the caller does not pass a `currency` argument and the offers carry
# no currency of their own; falls back to USD if unset. Passing the tool's
# `currency` argument is what actually changes the shared Wanderlog session's
# currency preference (a global side effect) — see the tool docs.
# WANDERLOG_DEFAULT_CURRENCY=USD

# OPTIONAL — required only if you run `npm run eval` (Phase 4 eval harness).
# Get a key from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — override models used by the eval harness. Defaults below.
# WANDERLOG_EVAL_MODEL=claude-sonnet-4-6
# WANDERLOG_EVAL_JUDGE_MODEL=claude-sonnet-4-6
